{
  "entryPoints": ["src/**/*.ts"],
  "name": "SudoSOS Back-end API",
  "docsRoot": "./docs/content",
  "out": "docs/content/typedoc",
  "includeVersion": true,
  "excludeExternals": true,
  "plugin": [
    "./docs/plugins/typedoc-plugin-strip-swagger-params.mjs",
    "typedoc-plugin-merge-modules",
    "typedoc-vitepress-theme",
    "typedoc-plugin-markdown",
    "./docs/plugins/typedoc-plugin-markdown-promote-docs.mjs"
  ],
  "mergeModulesRenameDefaults": true,
  "mergeModulesMergeMode": "module",
  "githubPages": false,
  "readme": "none",
  "entryFileName": "index.md",
  "indexFormat": "table",
  "useCodeBlocks": true,
  "disableSources": true,
  "parametersFormat": "table",
  "classPropertiesFormat": "table",
  "propertyMembersFormat": "table",
  "blockTags": [
    "@defaultValue",
    "@deprecated",
    "@example",
    "@jsx",
    "@param",
    "@privateRemarks",
    "@remarks",
    "@returns",
    "@see",
    "@throws",
    "@typeParam",
    "@author",
    "@callback",
    "@category",
    "@categoryDescription",
    "@default",
    "@document",
    "@extends",
    "@augments",
    "@yields",
    "@group",
    "@groupDescription",
    "@import",
    "@inheritDoc",
    "@license",
    "@module",
    "@mergeModuleWith",
    "@mergeTarget",
    "@prop",
    "@property",
    "@return",
    "@satisfies",
    "@since",
    "@sortStrategy",
    "@template",
    "@this",
    "@type",
    "@typedef",
    "@summary",
    "@preventInline",
    "@inlineType",
    "@preventExpand",
    "@expandType",
    "@operationId",
    "@tags",
    "@security",
    "@route",
    "@options",
    "@array",
    "@consumes",
    "@description",
    "@promote",
    "@index"
  ],
  "validation": {
    "notExported": false,
    "invalidLink": true,
    "invalidPath": true,
    "rewrittenLink": true,
    "notDocumented": false,
    "unusedMergeModuleWith": true
  }
}
